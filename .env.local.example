# ============================================================
# App Personal — Variables de entorno
# Copiar este archivo a .env.local y completar los valores
# NUNCA commitear .env.local al repositorio
# ============================================================

# --- Base de datos (Supabase) ---
# Connect to Supabase via connection pooling
DATABASE_URL="postgresql://postgres.xdudsnssqaxjxshmcrat:Mapa08082.Mapa08082@aws-1-us-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection to the database. Used for migrations
DIRECT_URL="postgresql://postgres.xdudsnssqaxjxshmcrat:Mapa08082.Mapa08082@aws-1-us-west-1.pooler.supabase.com:5432/postgres"

# --- NextAuth v5 ---
AUTH_SECRET="[generá con: openssl rand -base64 32]"
AUTH_URL="http://localhost:3000"

# Google OAuth (para NextAuth)
AUTH_GOOGLE_ID="[tu-google-client-id]"
AUTH_GOOGLE_SECRET="[tu-google-client-secret]"

# --- IA ---
ANTHROPIC_API_KEY="[tu-anthropic-api-key]"
OPENAI_API_KEY="[tu-openai-api-key-para-whisper]"

# --- Integraciones ---
# WhatsApp Business API (Sesión 8)
# WHATSAPP_TOKEN: Bearer token de la Graph API (Panel de Meta → App → WhatsApp → API Setup)
WHATSAPP_TOKEN=[tu-whatsapp-bearer-token]
# WHATSAPP_PHONE_ID: ID del número de teléfono del negocio (Phone Number ID en Meta)
WHATSAPP_PHONE_ID=[tu-phone-number-id]
# WHATSAPP_WABA_ID: WhatsApp Business Account ID
WHATSAPP_WABA_ID=[tu-waba-id]
# WEBHOOK_VERIFY_TOKEN: Token secreto que configurás en el panel de Meta para verificar el webhook
# Generar con: openssl rand -hex 20
WEBHOOK_VERIFY_TOKEN=

# Garmin Connect (Sesiones 3/4)
# Usá el email y contraseña de tu cuenta en connect.garmin.com
# La autenticación es SSO no oficial — válida para uso personal
# Para acceso oficial (app comercial): https://developer.garmin.com/health-api/overview/
GARMIN_EMAIL="tu-email@ejemplo.com"
GARMIN_PASSWORD="tu-contraseña-garmin"

# Cron Jobs (Vercel Cron — Sesión 3)
# Protege los endpoints /api/cron/* para que solo Vercel pueda llamarlos
# Generar con: openssl rand -base64 32
# También configurar en Vercel Dashboard → Project Settings → Environment Variables
CRON_SECRET="[generá con: openssl rand -base64 32]"

# Google Calendar (Sesión 7)
GOOGLE_CALENDAR_ID="primary"

# Notion (Sesión 6)
NOTION_API_KEY=""
NOTION_DATABASE_ID=""

# Notion Integration (Sesión 6)
# Estos valores se guardan en UserSettings por usuario (notionToken, notionDbId)
# Las vars de entorno son fallback global si el usuario no configuró sus credenciales
NOTION_TOKEN=   # Integration token de Notion (empieza con secret_)
NOTION_DB_ID=   # ID de la base de datos de Notion (formato: xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx)

# Lumina (Sesión 5)
LUMINA_API_URL=""
LUMINA_API_KEY=""

# --- Axiom (Logs) ---
# Token de API de Axiom (Settings → API Tokens en axiom.co)
AXIOM_TOKEN=""
# Nombre del dataset que creaste en Axiom
AXIOM_DATASET="app-personal"

# --- App de Finanzas (CONECTOR) ---
# URL base de la app de finanzas (default: https://finanzas-lemon.vercel.app)
FINANCES_APP_URL="https://finanzas-lemon.vercel.app"
# API key global de fallback (recomendado: configurar por usuario en Settings → Finanzas)
FINANCES_API_KEY=""
